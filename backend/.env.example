# Example environment variables for the FastAPI app

# DATABASE_URL: Async database connection string used by SQLAlchemy/databases.
# Example for SQLite (local): sqlite+aiosqlite:///./duckweed.db
DATABASE_URL=sqlite+aiosqlite:///./duckweed.db

# STORAGE_DIR: Directory where uploaded files and generated assets are stored.
STORAGE_DIR=./storage

# MODELS_DIR: Directory containing model weight files used by the app.
MODELS_DIR=./models/weights

# MAX_UPLOAD_SIZE_MB: Maximum allowed upload size (megabytes).
MAX_UPLOAD_SIZE_MB=50

# ALLOWED_ORIGINS: Comma-separated list of allowed CORS origins.
# Example: http://localhost:3000,https://example.com
ALLOWED_ORIGINS=http://localhost:3000

# YOLO_MODEL_PATH: Primary YOLO model weight file used for inference.
YOLO_MODEL_PATH=./models/weights/duckweed_v1.pt

# YOLO_FALLBACK_PATH: Fallback YOLO model weight file if primary is missing.
YOLO_FALLBACK_PATH=./models/weights/yolov8n-seg.pt

# ENVIRONMENT: Application environment (development, staging, production).
ENVIRONMENT=development

# LOG_LEVEL: Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL).
LOG_LEVEL=INFO
