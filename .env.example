# DATABASE_URL: Async SQLAlchemy connection string. Use sqlite+aiosqlite for local dev.
DATABASE_URL=sqlite+aiosqlite:///./duckweed.db

# STORAGE_DIR: Directory where uploaded images and generated overlays are stored.
STORAGE_DIR=./storage

# MODELS_DIR: Directory containing YOLO model weight files.
MODELS_DIR=./models/weights

# MAX_UPLOAD_SIZE_MB: Maximum allowed image upload size in megabytes.
MAX_UPLOAD_SIZE_MB=50

# ALLOWED_ORIGINS: Comma-separated CORS origins the frontend is served from.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# YOLO_MODEL_PATH: Primary fine-tuned model weights. Does not exist yet — created after first training run.
YOLO_MODEL_PATH=./models/weights/duckweed_v1.pt

# YOLO_FALLBACK_PATH: Base YOLOv8 weights used before fine-tuning and as training starting point.
YOLO_FALLBACK_PATH=./models/weights/yolov8n-seg.pt

# ENVIRONMENT: Controls logging format and debug behavior. Options: development, production.
ENVIRONMENT=development

# LOG_LEVEL: Structlog minimum level. Options: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO